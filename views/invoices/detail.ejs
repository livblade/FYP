<!-- Person 3: Responsible for invoice detail and status tracking views. -->
<%- include('../partials/header', { title: title }) %>
<%- include('../partials/navbar') %>

<main class="container-fluid py-4">
  <% if (!invoice) { %>
    <div class="alert alert-warning">Invoice not found.</div>
  <% } else { %>
  <div class="row g-3">
    <div class="col-12 col-lg-7">
      <div class="card shadow-sm">
        <div class="card-body">
          <h1 class="h4">Invoice Detail</h1>
          <p class="mb-1">Invoice ID: <strong><%= invoice.public_id %></strong></p>
          <p class="mb-1">Amount: SGD <strong><%= Number(invoice.amount_sgd).toFixed(2) %></strong></p>
          <p class="mb-1">Token: <strong><%= invoice.accepted_token %></strong></p>
          <p class="mb-1">Expires: <strong><%= new Date(invoice.expires_at).toLocaleString() %></strong></p>
          <p class="mb-1">Payment Link: <a href="<%= invoice.payment_link %>"><%= invoice.payment_link %></a></p>
          <p>Status: <span class="badge bg-secondary"><%= invoice.status %></span></p>
          <div class="d-flex gap-2 mt-3">
            <form action="/invoices/<%= invoice.public_id %>/update" method="post">
              <input type="hidden" name="status" value="EXPIRED" />
              <button class="btn btn-outline-warning btn-sm" type="submit">Mark Expired</button>
            </form>
            <form action="/invoices/<%= invoice.public_id %>/delete" method="post" onsubmit="return confirm('Delete this invoice?')">
              <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <div class="col-12 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h6">Payments</h2>
          <% if (!payments || payments.length === 0) { %>
            <p class="text-muted mb-0">No payments recorded yet.</p>
          <% } else { %>
            <ul class="list-group">
              <% payments.forEach((payment) => { %>
                <li class="list-group-item">
                  <div><strong><%= payment.status %></strong></div>
                  <div class="small text-muted">Hash: <%= payment.transaction_hash %></div>
                  <div class="small text-muted">Confirmations: <%= payment.confirmation_count %>/<%= payment.required_confirmations %></div>
                  <% if (payment.settlement) { %>
                    <div class="small">Settlement: <a href="/settlements/<%= payment.settlement.settlement_reference %>"><%= payment.settlement.settlement_reference %></a></div>
                  <% } %>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</main>

<%- include('../partials/footer') %>